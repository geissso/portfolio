---
const { currentPath = "/" } = Astro.props;
const links = [
  { href: "/", label: "Travaux" },
  { href: "/#experiences-benevoles", label: "Benevolat" },
  { href: "/contact", label: "Contact" }
];
---

<header class="fixed top-0 left-0 right-0 z-50 overflow-x-clip bg-background/80 backdrop-blur-md border-b border-border">
  <div class="container flex items-center justify-between h-14 px-3 sm:h-16 sm:px-6">
    <a href="/" class="block min-w-0 max-w-[calc(100%-5rem)]">
      <img
        src="/images/logo_sg.svg"
        alt="Logo Solene Geiss"
        class="h-10 w-auto sm:h-12 dark:hidden"
      />
      <img
        src="/images/logo_sg_light.svg"
        alt="Logo Solene Geiss"
        class="hidden h-10 w-auto sm:h-12 dark:block"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-body tracking-wide uppercase transition-colors ${
              currentPath === link.href ? "text-foreground" : "text-muted-foreground hover:text-foreground"
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <button
        id="theme-toggle"
        class="p-2 rounded-sm text-muted-foreground hover:text-foreground transition-colors"
        aria-label="Basculer le theme"
      >
        <svg data-icon="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
        </svg>
        <svg data-icon="sun" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
      </button>
    </nav>

    <div class="flex items-center gap-1 shrink-0 md:hidden">
      <button
        id="theme-toggle-mobile"
        class="grid h-8 w-8 place-items-center rounded-sm text-muted-foreground hover:text-foreground transition-colors"
        aria-label="Basculer le theme"
      >
        <svg data-icon="moon-mobile" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
        </svg>
        <svg data-icon="sun-mobile" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
      </button>

      <button
        id="mobile-menu-toggle"
        class="grid h-8 w-8 place-items-center rounded-sm border border-border text-foreground"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg data-icon="menu" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
        <svg data-icon="close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden w-full border-t border-border bg-background/95 backdrop-blur-md">
    <div class="container px-3 sm:px-6 py-4 flex flex-col gap-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`rounded-sm px-3 py-3 text-sm font-body uppercase tracking-wide transition-colors ${
              currentPath === link.href ? "text-foreground bg-card" : "text-muted-foreground hover:text-foreground hover:bg-card/70"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script is:inline>
  const themeToggle = document.querySelector("#theme-toggle");
  const themeToggleMobile = document.querySelector("#theme-toggle-mobile");
  const moon = document.querySelector('[data-icon="moon"]');
  const sun = document.querySelector('[data-icon="sun"]');
  const moonMobile = document.querySelector('[data-icon="moon-mobile"]');
  const sunMobile = document.querySelector('[data-icon="sun-mobile"]');
  const mobileMenuToggle = document.querySelector("#mobile-menu-toggle");
  const mobileMenu = document.querySelector("#mobile-menu");
  const menuIcon = document.querySelector('[data-icon="menu"]');
  const closeIcon = document.querySelector('[data-icon="close"]');

  const syncThemeIcon = () => {
    const isDark = document.documentElement.classList.contains("dark");
    if (isDark) {
      moon?.classList.add("hidden");
      sun?.classList.remove("hidden");
      moonMobile?.classList.add("hidden");
      sunMobile?.classList.remove("hidden");
    } else {
      moon?.classList.remove("hidden");
      sun?.classList.add("hidden");
      moonMobile?.classList.remove("hidden");
      sunMobile?.classList.add("hidden");
    }
  };

  const closeMobileMenu = () => {
    mobileMenu?.classList.add("hidden");
    mobileMenuToggle?.setAttribute("aria-expanded", "false");
    menuIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  };

  const toggleMobileMenu = () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    if (isOpen) {
      closeMobileMenu();
      return;
    }

    mobileMenu?.classList.remove("hidden");
    mobileMenuToggle?.setAttribute("aria-expanded", "true");
    menuIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
  };

  syncThemeIcon();

  themeToggle?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncThemeIcon();
  });

  themeToggleMobile?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncThemeIcon();
  });

  mobileMenuToggle?.addEventListener("click", toggleMobileMenu);

  mobileMenu?.querySelectorAll("a")?.forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      closeMobileMenu();
    }
  });
</script>
