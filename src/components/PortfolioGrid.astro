---
import { getPortfolioData } from "../js/backend.mjs";

const { categories, projects } = await getPortfolioData();
---

<section class="py-12 container px-6">
  <div class="flex flex-wrap gap-3 mb-12" id="portfolio-filters">
    {
      categories.map((cat) => (
        <button
          data-category={cat.key}
          class={`portfolio-filter px-4 py-2 text-xs font-body uppercase tracking-widest border transition-all duration-300 ${
            cat.key === "all"
              ? "bg-foreground text-background border-foreground"
              : "bg-transparent text-muted-foreground border-border hover:border-foreground hover:text-foreground"
          }`}
        >
          {cat.label}
        </button>
      ))
    }
  </div>

  {
    projects.length === 0 ? (
      <p class="text-muted-foreground font-body">Aucun projet trouve dans PocketBase.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5" id="portfolio-grid">
        {
          projects.map((project, i) => (
            <a
              href={`/projects/${project.id}`}
              data-project-category={project.category}
              class="portfolio-card group cursor-pointer animate-fade-in block no-underline"
              style={`animation-delay: ${i * 0.08}s;`}
            >
              <article class="h-full flex flex-col">
                <div class="overflow-hidden bg-card aspect-[4/5] border border-border group-hover:border-foreground transition-colors">
                  {
                    project.image ? (
                      <img
                        src={project.image}
                        alt={project.title}
                        loading="lazy"
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full grid place-items-center text-sm text-muted-foreground font-body">Image indisponible</div>
                    )
                  }
                </div>
                <div class="pt-3 pb-1 flex-1 flex flex-col">
                  <div class="flex items-baseline justify-between gap-4 mb-2">
                    <h3 class="font-heading text-lg text-foreground group-hover:text-accent transition-colors">
                      {project.title}
                    </h3>
                  </div>
                  <span class="text-xs font-body text-muted-foreground uppercase tracking-wider mb-2">
                    {categories.find((c) => c.key === project.category)?.label || project.categoryLabel}
                  </span>
                  <p class="text-sm text-muted-foreground font-body line-clamp-2">{project.description}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    )
  }
</section>

<script is:inline>
  const filterButtons = document.querySelectorAll(".portfolio-filter");
  const cards = document.querySelectorAll(".portfolio-card");

  const applyFilter = (activeCategory) => {
    cards.forEach((card) => {
      const category = card.getAttribute("data-project-category");
      const shouldShow = activeCategory === "all" || category === activeCategory;
      card.classList.toggle("hidden", !shouldShow);
    });

    filterButtons.forEach((button) => {
      const buttonCategory = button.getAttribute("data-category");
      const isActive = buttonCategory === activeCategory;
      button.classList.toggle("bg-foreground", isActive);
      button.classList.toggle("text-background", isActive);
      button.classList.toggle("border-foreground", isActive);
      button.classList.toggle("bg-transparent", !isActive);
      button.classList.toggle("text-muted-foreground", !isActive);
      button.classList.toggle("border-border", !isActive);
    });
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const category = button.getAttribute("data-category") || "all";
      applyFilter(category);
    });
  });
</script>
