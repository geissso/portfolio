---
const socialLinks = [
  {
    name: "Instagram",
    href: "https://www.instagram.com/sebrimmy/",
    label: "Voir le profil Instagram"
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/sol%C3%A8ne-geiss-158491337/",
    label: "Voir le profil LinkedIn"
  },
];
---

<footer class="mt-20 border-t border-border/80 bg-card/40 backdrop-blur-sm">
  <div class="container px-6 py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="space-y-2">
        <img
          src="/images/logo_sg.svg"
          alt="Logo Solene Geiss"
          class="h-8 w-auto"
        />
        <p class="text-xs font-body uppercase tracking-[0.2em] text-muted-foreground">
          Design visuel, web, conception et communication numerique.
        </p>
      </div>

      <div class="flex items-center gap-3" aria-label="Reseaux sociaux">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            target="_blank"
            rel="noopener noreferrer"
            class="group grid h-11 w-11 place-items-center rounded-xl border border-border bg-background/80 text-foreground transition-all duration-300 hover:-translate-y-0.5 hover:border-foreground hover:bg-background"
          >
            {link.name === "Instagram" && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4.2"></circle>
                <circle cx="17.4" cy="6.6" r="1"></circle>
              </svg>
            )}
            {link.name === "LinkedIn" && (
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
                <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5ZM.38 8.2h4.22V24H.38V8.2ZM8.03 8.2h4.04v2.16h.06c.56-1.07 1.94-2.2 4-2.2 4.28 0 5.07 2.82 5.07 6.48V24h-4.22v-7.73c0-1.84-.03-4.2-2.56-4.2-2.56 0-2.95 2-2.95 4.06V24H8.03V8.2Z" transform="scale(0.95) translate(0.6 0)"></path>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-8 border-t border-border/70 pt-4 text-xs font-body uppercase tracking-wider text-muted-foreground">
      © 2026 - Tous droits reserves
    </div>
  </div>
</footer>
