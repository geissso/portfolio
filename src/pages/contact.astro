---
import BaseLayout from "../layouts/BaseLayout.astro";

const POCKETBASE_URL = (import.meta.env.PUBLIC_POCKETBASE_URL || "https://pbportfolio.geiss-solene.fr/").replace(/\/$/, "");
const CONTACT_COLLECTION = import.meta.env.PUBLIC_CONTACT_COLLECTION || "messages";
---

<BaseLayout title="Contact - Portfolio" description="Discutons de votre projet.">
  <section class="container px-6 pt-32 pb-20">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-foreground"></div>
        <span class="text-xs font-body uppercase tracking-[0.3em] text-muted-foreground">Me contacter</span>
      </div>

      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl leading-[0.9] text-foreground mb-6">
        Discutons de<br />
        votre <span class="italic text-primary">projet</span><span class="text-secondary">.</span>
      </h1>

      <p class="text-base font-body text-muted-foreground leading-relaxed mb-12">
        Vous avez une idee, une collaboration ou un besoin de design ? Ecrivez-moi, je vous repondrai rapidement.
      </p>

      <form id="contact-form" class="space-y-6">
        <div>
          <label for="nom" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Nom</label>
          <input
            id="nom"
            name="nom"
            type="text"
            required
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors placeholder:text-muted-foreground/50"
            placeholder="Votre nom"
          />
        </div>

        <div>
          <label for="email" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors placeholder:text-muted-foreground/50"
            placeholder="ton.email@exemple.com"
          />
        </div>

        <div>
          <label for="message" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors resize-none placeholder:text-muted-foreground/50"
            placeholder="Ecrivez votre message ici..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="px-8 py-3 bg-foreground text-background text-xs font-body uppercase tracking-widest hover:opacity-80 transition-opacity"
        >
          Envoyer
        </button>

        <p id="contact-status" class="text-sm font-body text-muted-foreground" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ pocketbaseUrl: POCKETBASE_URL, contactCollection: CONTACT_COLLECTION }}>
  const contactForm = document.querySelector("#contact-form");
  const contactStatus = document.querySelector("#contact-status");
  const submitButton = contactForm?.querySelector('button[type="submit"]');

  const setStatus = (message, isError = false) => {
    if (!contactStatus) return;
    contactStatus.textContent = message;
    contactStatus.classList.toggle("text-secondary", !isError);
    contactStatus.classList.toggle("text-red-500", isError);
  };

  contactForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(contactForm);
    const nom = String(formData.get("nom") || "").trim();
    const email = String(formData.get("email") || "").trim();
    const message = String(formData.get("message") || "").trim();

    if (!nom || !email || !message) {
      setStatus("Merci de remplir tous les champs.", true);
      return;
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = "Envoi...";
    }

    setStatus("");

    try {
      const response = await fetch(`${pocketbaseUrl}/api/collections/${contactCollection}/records`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          nom,
          email,
          message
        })
      });

      if (!response.ok) {
        const errorPayload = await response.json().catch(() => null);
        const fallbackMessage = `Impossible d'envoyer le message (${response.status}).`;
        throw new Error(errorPayload?.message || fallbackMessage);
      }

      contactForm.reset();
      setStatus("Message envoyé.", false);
    } catch (error) {
      setStatus(error?.message || "Une erreur est survenue.", true);
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = "Envoyer";
      }
    }
  });
</script>
