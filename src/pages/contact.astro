---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact - Portfolio" description="Discutons de votre projet.">
  <section class="container px-6 pt-32 pb-20">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-foreground"></div>
        <span class="text-xs font-body uppercase tracking-[0.3em] text-muted-foreground">Me contacter</span>
      </div>

      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl leading-[0.9] text-foreground mb-6">
        Discutons de<br />
        votre <span class="italic text-primary">projet</span><span class="text-secondary">.</span>
      </h1>

      <p class="text-base font-body text-muted-foreground leading-relaxed mb-12">
        Vous avez une idee, une collaboration ou un besoin de design ? Ecrivez-moi, je vous repondrai rapidement.
      </p>

      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Nom</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors placeholder:text-muted-foreground/50"
            placeholder="Lorem Ipsum"
          />
        </div>

        <div>
          <label for="email" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors placeholder:text-muted-foreground/50"
            placeholder="lorem@ipsum.com"
          />
        </div>

        <div>
          <label for="message" class="block text-xs font-body uppercase tracking-widest text-muted-foreground mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full bg-transparent border-b border-border py-3 text-foreground font-body focus:outline-none focus:border-primary transition-colors resize-none placeholder:text-muted-foreground/50"
            placeholder="Dolor sit amet consectetur..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="px-8 py-3 bg-foreground text-background text-xs font-body uppercase tracking-widest hover:opacity-80 transition-opacity"
        >
          Envoyer
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const contactForm = document.querySelector("#contact-form");

  contactForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    alert("Message envoye !");
    contactForm.reset();
  });
</script>
