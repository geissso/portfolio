---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page introuvable" description="La page demandee est introuvable.">
  <section class="container px-6 py-32 flex items-center justify-center">
    <div class="text-center max-w-xl">
      <h1 class="mb-4 text-6xl font-heading">404</h1>
      <p class="mb-6 text-xl text-muted-foreground">Oups, cette page n'existe pas.</p>
      <a href="/" class="text-primary underline hover:text-primary/90">Retour a l'accueil</a>
    </div>
  </section>
</BaseLayout>
