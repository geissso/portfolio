---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import PortfolioGrid from "../components/PortfolioGrid.astro";
import ExperiencesBenevoles from "../components/ExperiencesBenevoles.astro";
---

<BaseLayout title="Portfolio" description="Portfolio de Solene Geiss: travaux artistiques et digitaux.">
  <HeroSection />
  <div class="container px-6 py-8">
    <a
      href="/cv.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-body text-primary hover:text-primary/80 transition-colors uppercase tracking-widest"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Ouvrir mon CV
    </a>
  </div>
  <PortfolioGrid />
  <ExperiencesBenevoles />
</BaseLayout>
